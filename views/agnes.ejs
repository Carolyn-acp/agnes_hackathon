<%- include('partials/header') %>

<section class="section-header">
  <div>
    <p class="eyebrow">Agnes travel agents</p>
    <h1>Plan a weather-aware trip</h1>
    <p>Enter the trip details and Agnes will create itinerary, weather, wardrobe, packing, budget, and outfit-preview outputs.</p>
  </div>
</section>

<% if (error) { %>
  <p class="alert"><%= error %></p>
<% } %>

<section class="tool-panel trip-builder">
  <h2>Trip inputs</h2>
  <form action="/agnes/trip" method="post">
    <div class="form-grid">
      <label>
        Destination
        <input name="destination" type="text" placeholder="Tokyo, Japan" value="<%= destination %>" required>
      </label>

      <label>
        Budget
        <input name="budget" type="text" placeholder="$1200 for 5 days" value="<%= budget %>" required>
      </label>

      <label>
        Dates
        <input name="travelDates" type="text" placeholder="July 3-7" value="<%= travelDates %>">
      </label>

      <label>
        Weather you already know
        <input name="weatherNotes" type="text" placeholder="Hot, rainy, humid, cold nights..." value="<%= weatherNotes %>">
      </label>
    </div>

    <label>
      Wardrobe photos or clothes list
      <textarea name="wardrobe" rows="5" placeholder="Describe uploaded wardrobe photos for now: white sneakers, black jeans, blue rain jacket, floral dress..."><%= wardrobe %></textarea>
    </label>

    <button type="submit">Generate trip plan</button>
  </form>
</section>

<% if (tripPlan) { %>
  <section class="agent-results">
    <article class="agent-card">
      <p class="eyebrow">Agent 1</p>
      <h2>Research Agent</h2>
      <p><%= tripPlan.itinerary %></p>
    </article>

    <article class="agent-card weather-card">
      <p class="eyebrow">Agent 2</p>
      <h2>Weather Agent</h2>
      <p><%= tripPlan.weather %></p>
    </article>

    <article class="agent-card">
      <p class="eyebrow">Agent 3</p>
      <h2>Wardrobe Agent</h2>
      <p><%= tripPlan.wardrobe %></p>
    </article>

    <article class="agent-card">
      <p class="eyebrow">Agent 4</p>
      <h2>Packing Agent</h2>
      <p><%= tripPlan.packing %></p>
    </article>

    <article class="agent-card">
      <p class="eyebrow">Agent 5</p>
      <h2>Spending Agent</h2>
      <p><%= tripPlan.spending %></p>
    </article>

    <article class="agent-card">
      <p class="eyebrow">Agent 6</p>
      <h2>Visual Agent</h2>
      <% if (imageResult) { %>
        <% if (imageResult.startsWith('http')) { %>
          <img class="generated-image" src="<%= imageResult %>" alt="Daily outfit preview generated by Agnes AI">
        <% } else { %>
          <img class="generated-image" src="data:image/png;base64,<%= imageResult %>" alt="Daily outfit preview generated by Agnes AI">
        <% } %>
      <% } else if (visualError) { %>
        <p class="inline-error">Image preview could not be generated: <%= visualError %></p>
        <p><%= tripPlan.outfitPrompt %></p>
      <% } else { %>
        <p><%= tripPlan.outfitPrompt %></p>
      <% } %>
    </article>
  </section>
<% } %>

<%- include('partials/footer') %>
