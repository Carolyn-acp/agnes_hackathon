<%- include('partials/header') %>

<section class="section-header">
  <div>
    <p class="eyebrow">Agnes API</p>
    <h1>Generate with Agnes AI</h1>
  </div>
</section>

<% if (error) { %>
  <p class="alert"><%= error %></p>
<% } %>

<div class="agnes-grid">
  <section class="tool-panel">
    <h2>Text</h2>
    <form action="/agnes/text" method="post">
      <label for="text-prompt">Prompt</label>
      <textarea id="text-prompt" name="prompt" rows="5" placeholder="Ask Agnes something..." required><%= textPrompt %></textarea>
      <button type="submit">Generate text</button>
    </form>

    <% if (textResult) { %>
      <div class="result-box">
        <h3>Response</h3>
        <p><%= textResult %></p>
      </div>
    <% } %>
  </section>

  <section class="tool-panel">
    <h2>Image</h2>
    <form action="/agnes/image" method="post">
      <label for="image-prompt">Prompt</label>
      <textarea id="image-prompt" name="prompt" rows="5" placeholder="Describe the image..." required><%= imagePrompt %></textarea>
      <button type="submit">Generate image</button>
    </form>

    <% if (imageResult) { %>
      <div class="result-box">
        <h3>Image</h3>
        <% if (imageResult.startsWith('http')) { %>
          <img class="generated-image" src="<%= imageResult %>" alt="Generated by Agnes AI">
        <% } else { %>
          <img class="generated-image" src="data:image/png;base64,<%= imageResult %>" alt="Generated by Agnes AI">
        <% } %>
      </div>
    <% } %>
  </section>
</div>

<%- include('partials/footer') %>
