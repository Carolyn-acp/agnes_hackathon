<%- include('partials/header') %>

<section class="section-header">
  <div>
    <p class="eyebrow">Agnes itinerary agent</p>
    <h1>Plan your trip itinerary</h1>
    <p>Choose a country, city, places, budget, and trip length. Agnes will create one itinerary card per day with weather.</p>
  </div>
</section>

<% if (error) { %>
  <p class="alert"><%= error %></p>
<% } %>

<section class="tool-panel trip-builder">
  <h2>Trip inputs</h2>
  <form action="/agnes/trip" method="post">
    <div class="form-grid">
      <label>
        Country
        <input name="country" type="text" list="country-options" placeholder="Search country" value="<%= country %>" data-country-input required>
        <datalist id="country-options" data-country-list></datalist>
        <span class="field-status" data-country-status></span>
      </label>

      <label>
        City
        <input name="city" type="text" list="city-options" placeholder="Choose a country first" value="<%= city %>" data-city-input required>
        <datalist id="city-options" data-city-list></datalist>
        <span class="field-status" data-city-status></span>
      </label>

      <label>
        Budget
        <input name="budget" type="text" placeholder="$1200 for 5 days" value="<%= budget %>" required>
      </label>

      <label>
        Days
        <input name="days" type="number" min="1" max="30" placeholder="5" value="<%= days %>" required>
      </label>

      <label>
        Dates
        <input name="travelDates" type="text" placeholder="July 3-7" value="<%= travelDates %>">
      </label>
    </div>

    <label>
      Places you want to go
      <textarea name="places" rows="5" placeholder="Tokyo Tower&#10;Shibuya Crossing&#10;Senso-ji&#10;teamLab" required><%= places %></textarea>
    </label>

    <button type="submit">Generate trip plan</button>
  </form>
</section>

<% const dayCards = tripPlan && Array.isArray(tripPlan.days) ? tripPlan.days : []; %>

<% if (tripPlan) { %>
  <section class="section-header">
    <div>
      <p class="eyebrow">Research Agent</p>
      <h1>Your itinerary</h1>
    </div>
  </section>

  <section class="day-grid">
    <% if (!dayCards.length) { %>
      <article class="day-card">
        <p class="eyebrow">No days</p>
        <h2>Try generating again</h2>
        <p>Agnes returned a response, but it did not include day cards.</p>
      </article>
    <% } %>

    <% dayCards.forEach((day) => { %>
      <article class="day-card">
        <p class="eyebrow">Day <%= day.day %></p>
        <h2><%= day.title %></h2>

        <div class="weather-strip">
          <strong>Weather</strong>
          <p><%= day.weather %></p>
        </div>

        <h3>Plan</h3>
        <ul>
          <% (Array.isArray(day.activities) ? day.activities : [day.activities].filter(Boolean)).forEach((activity) => { %>
            <li><%= activity %></li>
          <% }) %>
        </ul>

        <% const attractionsForDay = Array.isArray(day.attractions) ? day.attractions : []; %>
        <% if (attractionsForDay.length) { %>
          <h3>Attractions</h3>
          <ul>
            <% attractionsForDay.forEach((attraction) => { %>
              <li>
                <strong><%= attraction.name %></strong>
                <span class="source-pill"><%= attraction.source %></span>
              </li>
            <% }) %>
          </ul>
        <% } %>

        <% if (day.budgetNote) { %>
          <p><strong>Budget:</strong> <%= day.budgetNote %></p>
        <% } %>
      </article>
    <% }) %>
  </section>
<% } %>

<script src="/js/locationPicker.js"></script>

<%- include('partials/footer') %>
