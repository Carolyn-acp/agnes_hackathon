<%- include('partials/header') %>

<section class="section-header">
  <div>
    <p class="eyebrow">Agnes itinerary agent</p>
    <h1>Plan your trip itinerary</h1>
    <p>Choose a country, city, places, budget, and trip length. Agnes will create one itinerary card per day with weather.</p>
  </div>
</section>

<% if (error) { %>
  <p class="alert"><%= error %></p>
<% } %>

<section class="tool-panel trip-builder">
  <h2>Trip inputs</h2>
  <form action="/agnes/trip" method="post">
    <div class="form-grid">
      <label>
        Country
        <input name="country" type="text" list="country-options" placeholder="Search country" value="<%= country %>" data-country-input required>
        <datalist id="country-options" data-country-list></datalist>
        <span class="field-status" data-country-status></span>
      </label>

      <label>
        City
        <input name="city" type="text" list="city-options" placeholder="Choose a country first" value="<%= city %>" data-city-input required>
        <datalist id="city-options" data-city-list></datalist>
        <span class="field-status" data-city-status></span>
      </label>

      <label>
        Budget
        <input name="budget" type="text" placeholder="$1200 for 5 days" value="<%= budget %>" required>
      </label>

      <fieldset class="date-range">
        <legend>Trip dates</legend>
        <div class="date-range-inputs">
          <label>
            Start
            <input name="startDate" type="date" value="<%= startDate %>" data-start-date required>
          </label>

          <label>
            End
            <input name="endDate" type="date" value="<%= endDate %>" data-end-date required>
          </label>
        </div>
      </fieldset>

      <label>
        Days
        <input name="days" type="number" min="1" max="30" placeholder="Auto" value="<%= days %>" data-days-input readonly required>
        <span class="field-status" data-days-status>Choose start and end dates.</span>
      </label>
    </div>

    <label>
      Places you want to go
      <textarea name="places" rows="5" placeholder="Tokyo Tower&#10;Shibuya Crossing&#10;Senso-ji&#10;teamLab" required><%= places %></textarea>
    </label>

    <button type="submit">Generate trip plan</button>
  </form>
</section>

<% const dayCards = tripPlan && Array.isArray(tripPlan.days) ? tripPlan.days : []; %>

<% if (tripPlan) { %>
  <section class="section-header">
    <div>
      <p class="eyebrow">Research Agent</p>
      <h1>Your itinerary</h1>
    </div>
  </section>

  <section class="day-grid">
    <% if (!dayCards.length) { %>
      <article class="day-card">
        <p class="eyebrow">No days</p>
        <h2>Try generating again</h2>
        <p>Agnes returned a response, but it did not include day cards.</p>
      </article>
    <% } %>

    <% dayCards.forEach((day) => { %>
      <article class="day-card">
        <p class="eyebrow">Day <%= day.day %></p>
        <h2><%= day.title %></h2>

        <div class="weather-strip">
          <strong>Weather</strong>
          <p><%= day.weather %></p>
        </div>

        <h3>Plan</h3>
        <ul>
          <% (Array.isArray(day.activities) ? day.activities : [day.activities].filter(Boolean)).forEach((activity) => { %>
            <li><%= activity %></li>
          <% }) %>
        </ul>
    <% if (budgetPlan) { %>
      <article class="agent-card budget-card">
        <p class="eyebrow">Agent 5</p>
        <h2>Budget Planner</h2>
        <div class="budget-metrics">
          <div>
            <span>Total</span>
            <strong><%= budgetPlan.totalBudget %></strong>
          </div>
          <div>
            <span>Daily guide</span>
            <strong><%= budgetPlan.dailyAverage %></strong>
          </div>
          <div>
            <span>Trip buffer</span>
            <strong><%= budgetPlan.emergencyBuffer %></strong>
          </div>
        </div>
        <p><%= budgetPlan.summary %></p>
      </article>
    <% } else { %>
      <article class="agent-card">
        <p class="eyebrow">Agent 5</p>
        <h2>Spending Agent</h2>
        <p><%= tripPlan.spending %></p>
      </article>
    <% } %>

        <% const attractionsForDay = Array.isArray(day.attractions) ? day.attractions : []; %>
        <% if (attractionsForDay.length) { %>
          <h3>Attractions</h3>
          <ul>
            <% attractionsForDay.forEach((attraction) => { %>
              <li>
                <strong><%= attraction.name %></strong>
                <span class="source-pill"><%= attraction.source %></span>
              </li>
            <% }) %>
          </ul>
        <% } %>

        <% if (day.budgetNote) { %>
          <p><strong>Budget:</strong> <%= day.budgetNote %></p>
        <% } %>
      </article>
    <% }) %>
  </section>

  <% if (budgetPlan) { %>
    <section class="budget-planner">
      <div class="section-header">
        <div>
          <p class="eyebrow">Your budget segment</p>
          <h2>Daily spending guidelines</h2>
          <p>Use these caps while following the itinerary so each day stays balanced across food, transport, activities, shopping, and backup money.</p>
        </div>
      </div>

      <div class="budget-day-grid">
        <% budgetPlan.dayPlans.forEach((dayPlan) => { %>
          <article class="budget-day">
            <div class="budget-day-header">
              <div>
                <p class="eyebrow"><%= dayPlan.title %></p>
                <h3><%= dayPlan.dailyLimit %> max</h3>
              </div>
            </div>

            <div class="category-grid">
              <div><span>Food</span><strong><%= dayPlan.categories.food %></strong></div>
              <div><span>Transport</span><strong><%= dayPlan.categories.transport %></strong></div>
              <div><span>Activities</span><strong><%= dayPlan.categories.activities %></strong></div>
              <div><span>Shopping</span><strong><%= dayPlan.categories.shopping %></strong></div>
              <div><span>Buffer</span><strong><%= dayPlan.categories.buffer %></strong></div>
            </div>

            <ul class="place-guidance">
              <% dayPlan.places.forEach((place) => { %>
                <li>
                  <strong><%= place.place %></strong>
                  <span><%= place.guidance %></span>
                </li>
              <% }) %>
            </ul>

            <p class="budget-tip"><%= dayPlan.tip %></p>
          </article>
        <% }) %>
      </div>
    </section>
  <% } %>
<% } %>

<% if (packingList && packingList.categories) { %>
  <section class="section-header">
    <div>
      <p class="eyebrow">Generated</p>
      <h2>Recommended Packing List</h2>
    </div>
  </section>

  <section class="day-grid">
    <% packingList.categories.forEach(category => { %>
      <article class="day-card">
        <h3><%= category.name %></h3>
        <ul>
          <% category.items.forEach(item => { %>
            <li><%= item %></li>
          <% }) %>
        </ul>
      </article>
    <% }) %>
  </section>
<% } %>

<script src="/js/locationPicker.js"></script>

<%- include('partials/footer') %>
